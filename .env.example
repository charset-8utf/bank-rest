# Скопируй этот файл в .env и подставь свои значения
# cp .env.example .env

# JWT — Base64-строка длиной не менее 32 байт
JWT_SECRET=replace_with_your_base64_secret_min_32_bytes
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# AES-256-GCM ключ шифрования номеров карт — Base64, ровно 32 байта
CARD_ENCRYPTION_SECRET=replace_with_your_base64_32_byte_key

# База данных
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/bankcards_db
SPRING_DATASOURCE_USERNAME=bankcards_user
SPRING_DATASOURCE_PASSWORD=bankcards_pass
